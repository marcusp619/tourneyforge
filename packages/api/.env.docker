# ─── Local Docker Dev Environment ───────────────────────────────────────────
# Copy this to .env to run the API against local Docker services.
#
#   cp packages/api/.env.docker packages/api/.env

# ── Database (local Postgres) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://tf:tfpassword@localhost:5432/tourneyforge

# ── Storage (MinIO — S3-compatible R2 replacement) ───────────────────────────
# R2_ENDPOINT overrides the Cloudflare R2 URL; the S3 client uses this instead.
R2_ENDPOINT=http://localhost:9000
R2_BUCKET_NAME=tourneyforge
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
# Public base URL used to build logo URLs after upload
R2_PUBLIC_URL=http://localhost:9000/tourneyforge
# R2_ACCOUNT_ID is not needed when R2_ENDPOINT is set
R2_ACCOUNT_ID=local

# ── Email (Mailpit SMTP — open http://localhost:8025 to view sent emails) ─────
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM_DOMAIN=noreply@tourneyforge.local

# ── Redis (leave blank to skip rate limiting and custom domain lookups) ────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Clerk (leave blank — API doesn't use Clerk directly) ─────────────────────

# ── Stripe (use test keys from https://dashboard.stripe.com/test/apikeys) ────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic AI (for catch verification — optional) ─────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio SMS (optional) ────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
